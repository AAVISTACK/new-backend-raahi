NODE_ENV=development

# PORT — Railway injects this automatically in production.
# For local development only: set this manually in your .env file.
# DO NOT set PORT in Railway dashboard — Railway manages it automatically.
PORT=3000

# PostgreSQL (Railway pe milega automatically via DATABASE_URL env var)
DATABASE_URL=postgresql://user:password@host:5432/raahi_db

# JWT
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_minimum_64_characters_long
JWT_EXPIRY=30d

# Firebase Admin SDK
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Gemini AI (aistudio.google.com se lo)
GEMINI_API_KEY=your_gemini_api_key

# Admin Secret (selfie review screen ke liye)
ADMIN_SECRET=raahi_admin_secret_2024

# CORS — Flutter app origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://raahi.in

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
